---
interface Props {
  skill: {
    name: string;
    level: string;
  };
}

const { skill } = Astro.props;

const levelColor =
  skill.level === "Strong"
    ? "bg-green-500/20 text-green-400"
    : skill.level === "Comfortable"
      ? "bg-blue-500/20 text-blue-400"
      : "bg-yellow-500/20 text-yellow-400";
---

<div
  class="group rounded-xl border border-neutral/20 bg-neutral/5 p-4 transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-lg hover:shadow-primary/10"
>
  <div class="flex items-center justify-between">
    <h3 class="font-semibold text-white">
      {skill.name}
    </h3>

    <span class={`rounded-full px-3 py-1 text-xs font-medium ${levelColor}`}>
      {skill.level}
    </span>
  </div>
</div>
